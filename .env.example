# ──────────────────────────────────────────────────────────────────────────
# Integration credentials for the AI Security Stack Mapper.
#
# Until these are set, every integration runs in MOCK mode (no network calls).
#
# SECURITY NOTES:
#  - Never commit a real .env file. Only this .env.example belongs in VCS.
#  - In this Vite frontend, only VITE_-prefixed vars are exposed to the bundle.
#    Exposing a real secret to the browser is unsafe — for production, proxy
#    these calls through a backend that holds the UNPREFIXED variables below
#    and keeps the keys server-side.
#  - All calls use HTTPS; TLS verification is never disabled.
# ──────────────────────────────────────────────────────────────────────────

# Check Point Threat Emulation
CHECKPOINT_TE_API_KEY=
CHECKPOINT_TE_BASE_URL=https://te.checkpoint.com/api

# Check Point TE File Scan
CHECKPOINT_FILE_SCAN_API_KEY=
CHECKPOINT_FILE_SCAN_BASE_URL=https://te.checkpoint.com/tecloud/api/v1/file

# Lakera Guard
LAKERA_GUARD_API_KEY=
LAKERA_GUARD_BASE_URL=https://api.lakera.ai/v2

# ── Frontend (dev only) mirrors — prefix with VITE_ to expose to the browser.
# Prefer a backend proxy in production rather than setting these.
# VITE_CHECKPOINT_TE_API_KEY=
# VITE_CHECKPOINT_TE_BASE_URL=
# VITE_CHECKPOINT_FILE_SCAN_API_KEY=
# VITE_CHECKPOINT_FILE_SCAN_BASE_URL=
# VITE_LAKERA_GUARD_API_KEY=
# VITE_LAKERA_GUARD_BASE_URL=
