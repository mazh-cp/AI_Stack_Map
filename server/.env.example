# ──────────────────────────────────────────────────────────────────────────
# Backend configuration for the AI Security Stack Mapper API.
# Copy to .env and adjust. NEVER commit a real .env.
# ──────────────────────────────────────────────────────────────────────────

# SQLite database (Prisma). A file-based DB needs no external service.
DATABASE_URL="file:./dev.db"

# HTTP server
PORT=4000
# Comma-separated list of allowed CORS origins (the Vite dev server)
CORS_ORIGIN="http://localhost:5173"

# Auth — signing secret for JWTs. If unset, an ephemeral secret is generated at
# boot (tokens reset on restart). Set a strong value for stable sessions.
JWT_SECRET=

# ── Vendor integration credentials (kept SERVER-SIDE only) ──────────────────
# Until set, integrations run in MOCK mode (no outbound calls).
# All live calls use HTTPS; TLS verification is never disabled.
CHECKPOINT_TE_API_KEY=
CHECKPOINT_TE_BASE_URL="https://te.checkpoint.com/api"
CHECKPOINT_FILE_SCAN_API_KEY=
CHECKPOINT_FILE_SCAN_BASE_URL="https://te.checkpoint.com/tecloud/api/v1/file"
LAKERA_GUARD_API_KEY=
LAKERA_GUARD_BASE_URL="https://api.lakera.ai/v2"
